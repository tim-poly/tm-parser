# Thread safety
sku_lock = threading.Lock()

class RequestScheduler:

    def __init__(self):

        self.rate = 0.8      # tokens added per second
        self.capacity = 4    # max burst
        self.tokens = 4

        self.last_refill = time.time()
        self.lock = threading.Lock()

    def wait(self):

        while True:

            with self.lock:

                now = time.time()
                elapsed = now - self.last_refill

                # refill tokens
                new_tokens = elapsed * self.rate
                self.tokens = min(self.capacity, self.tokens + new_tokens)

                self.last_refill = now

                if self.tokens >= 1:
                    self.tokens -= 1
                    return

            time.sleep(random.uniform(0.1, 0.3))

    def success(self):
        pass

    def rate_limited(self):

        with self.lock:

            # slow down token generation
            self.rate = max(0.5, self.rate * 0.7)

            print(f"Rate limit detected → new request rate {round(self.rate,2)} req/sec")

scheduler = RequestScheduler()

global_cooldown_until = 0
cooldown_lock = threading.Lock()

def fetch_page(url, retries=4):

    global global_cooldown_until

    for attempt in range(retries):

        # respect global cooldown
        with cooldown_lock:
            if time.time() < global_cooldown_until:
                wait = global_cooldown_until - time.time()
                print(f"Global cooldown {round(wait,1)}s")
                time.sleep(wait)

        scheduler.wait()

        try:
            response = SESSION.get(
                url,
                headers={
                    "User-Agent": random.choice(USER_AGENTS),
                    "Accept": "text/html,application/xhtml+xml",
                    "Referer": "https://www.thomann.se/"
                },
                timeout=15
            )

            if response.status_code == 404:
                print(f"404 page: {url}")
                return None

            if response.status_code == 429:

                print("429 Too Many Requests")

                scheduler.rate_limited()

                cooldown = random.uniform(25,40)

                with cooldown_lock:
                    global_cooldown_until = time.time() + cooldown

                print(f"Cooling down for {round(cooldown,1)} seconds")

                time.sleep(cooldown)

                continue

            if response.status_code >= 500:
                print("Server error")
                scheduler.rate_limited()
                continue

            response.raise_for_status()

            scheduler.success()

            return response.text

        except requests.RequestException as e:

            backoff = min(30, 2 ** attempt)
            jitter = random.uniform(0.5, 1.5)
            wait = backoff * jitter

            print(f"Request failed: {e}")
            print(f"Retry {attempt+1}/{retries} in {round(wait,1)} seconds")

            time.sleep(float(wait))

    return None


